# Clerk Authentication
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Frontend API Base URL (set this in Vercel environment)
VITE_API_BASE_URL=your_backend_url_here

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/coinDrop?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here

# Cloudinary — set these in backend environment (NEVER in frontend/client env)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name_here
CLOUDINARY_API_KEY=your_cloudinary_api_key_here
CLOUDINARY_API_SECRET=your_cloudinary_api_secret_here

# Other environment variables
NODE_ENV=development
PORT=5000
