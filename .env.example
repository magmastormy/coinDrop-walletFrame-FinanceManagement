# =========================================================
# FRONTEND ENVIRONMENT VARIABLES (set these in Vercel)
# =========================================================
# File: .env (local) or Vercel Dashboard → Settings → Environment Variables
#
# Clerk Authentication (frontend-only auth service)
# Get your keys at: https://dashboard.clerk.com
VITE_CLERK_PUBLISHABLE_KEY=pk_test_your_clerk_publishable_key_here

# Backend API URL (your Render backend URL + /api)
# Example: https://coindrop-backend-xxxx.onrender.com/api
VITE_API_BASE_URL=https://your-render-backend-url.onrender.com/api

# =========================================================
# BACKEND ENVIRONMENT VARIABLES (set these in Render)
# =========================================================
# File: render.yaml or Render Dashboard → Environment tab
#
# Node environment
NODE_ENV=production
PORT=5000

# MongoDB Atlas Connection String
MONGODB_URI=mongodb+srv://<username>:<password>@<cluster>.mongodb.net/coinDrop?retryWrites=true&w=majority

# JWT Secret for authentication
JWT_SECRET=your_jwt_secret_here
JWT_EXPIRES_IN=7d

# Encryption key (32-byte hex string for field-level encryption)
ENCRYPTION_KEY=abcdef01234567890abcdef01234567890abcdef01234567890abcdef0123456

# CORS - comma-separated list of allowed frontend origins
CORS_ORIGIN=https://your-app.vercel.app,http://localhost:5173

# Cloudinary (image uploads - set in backend only, NEVER in frontend)
CLOUDINARY_CLOUD_NAME=your_cloudinary_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret

# NVIDIA API (OpenAI-compatible, for AI features)
NVIDIA_API_KEY=your_nvidia_api_key_here

# Logging
LOG_LEVEL=info

# Redis (OPTIONAL - only if you have a Redis service)
# REDIS_HOST=your-redis-host
# REDIS_PORT=6379
# REDIS_PASSWORD=your-redis-password